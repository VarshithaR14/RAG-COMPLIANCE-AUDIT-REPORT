# ─── LLM API Keys ─────────────────────────────────────────────
# Primary LLM (GPT-4o)
OPENAI_API_KEY= your_openai_api_key_here

# Fallback LLM (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Second fallback (local Ollama — optional)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:varshu@localhost:5432/compliance_db

# ─── Vector DB ─────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Storage ───────────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads
REPORTS_DIR=/tmp/compliance_reports_

# ─── Embedding Model ───────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
